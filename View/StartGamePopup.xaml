<Window x:Class="ASI_GuessTheNumber.View.StartGamePopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ASI_GuessTheNumber.View"
        WindowStyle="None"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        Background="#111827"
        AllowsTransparency="True">

    <Border   Background="#111827"
            CornerRadius="10"
            BorderBrush="#CCCCCC"
            BorderThickness="1"
            Padding="20"
            Width="300">

        <StackPanel>

            <TextBlock Text="Start New Game"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#f18832"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Choose a range:"
                         Foreground="White"
                       FontSize="14"
                       Margin="0,0,0,5"/>

            <ComboBox ItemsSource="{Binding RangeOptions}"
                      SelectedItem="{Binding SelectedRange}"
                      FontSize="14"
                  
                      Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <Button Content="Start"
                        Width="90"
                        Padding="5"
                        Command="{Binding StartCommand}"
                   Foreground="#24374b"
                    Background="#f18832"
                     Margin="0,0,60,0"
                        BorderThickness="0"/>

                <Button Content="Cancel"
                        Width="90"
                        Padding="5"
                        Command="{Binding CancelCommand}"
                       Foreground="#24374b"
                            Background="#f18832"
                        BorderThickness="0"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>

