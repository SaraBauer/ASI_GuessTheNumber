<Window x:Class="ASI_GuessTheNumber.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ASI_GuessTheNumber"
        mc:Ignorable="d"
        Title="MainWindow" 
        Height="450"
        Width="800"
        Background="#111827">
    <Grid>
        <StackPanel Margin="20" VerticalAlignment="Center">
            <TextBlock Text="Guess The Number"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#f18832"
                           HorizontalAlignment="Center"/>
            
            <TextBlock Text="Winner Winner Chicken Dinner"
           FontSize="28"
           FontWeight="Bold"
           Foreground="#f15832"
           HorizontalAlignment="Center"
           Margin="0,0,0,0"
           Visibility="{Binding IsGameFinished, Converter={StaticResource BoolToVisibilityConverter}}" />

            <Button Content="Click here to start the adventure"
        Command="{Binding ShowStartPopupCommand}"
        IsEnabled="{Binding IsStartEnabled}"
                    Foreground="#24374b"
                    Background="#f18832"
        Visibility="{Binding IsStartEnabled, Converter={StaticResource BoolToVisibilityConverter}}"
        FontSize="18"
        Padding="10"
        Margin="0,0,0,20"
        HorizontalAlignment="Center"/>

            
                <TextBox Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
             FontSize="16"
                  Margin="0,5,0,0"
                     Foreground="#24374b"
                       
            Visibility="{Binding IsStartEnabled, Converter={StaticResource InverseBoolToVisibilityConverter}}"
             PreviewTextInput="NumberOnly" />

            <TextBlock Text="{Binding ErrorMessage}"
               Foreground="#d3deea"
               FontSize="14"
               Visibility="{Binding IsStartEnabled, Converter={StaticResource InverseBoolToVisibilityConverter}}"
               Margin="0,5,0,0" />

            <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">
                <Button Content="Guess"
                Command="{Binding ProcessNumberCommand}" 
                            Foreground="#24374b"
                        Background="#f18832"
                         Width="140"
                            Height="45"
                 Visibility="{Binding IsStartEnabled, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                Margin="0,10,60,0"
                FontSize="16" />

                <Button Content="New Game"
                Command="{Binding CancelGameCommand}"
                Margin="0,10,0,0"
                         Width="140"
                            Height="45"
              
                            Foreground="#24374b"
                            Background="#f18832"
                Visibility="{Binding IsStartEnabled, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                FontSize="16" />
                
            </StackPanel>
            <TextBlock Text="Attempts:"
               FontSize="14"
               Foreground="#d3deea"
             Visibility="{Binding IsStartEnabled, Converter={StaticResource InverseBoolToVisibilityConverter}}"
               Margin="0,15,0,0" />

            <TextBlock Text="{Binding GuessCount}"
               FontSize="18"
               Visibility="{Binding IsStartEnabled, Converter={StaticResource InverseBoolToVisibilityConverter}}"
               Foreground= "#d3deea" />

            <TextBlock Text="Time:"
               FontSize="14"
                Foreground="#d3deea"
               Visibility="{Binding IsStartEnabled, Converter={StaticResource InverseBoolToVisibilityConverter}}"
               Margin="0,15,0,0" />

            <TextBlock Text="{Binding TimeElapsed}"
               FontSize="18"
              Visibility="{Binding IsStartEnabled, Converter={StaticResource InverseBoolToVisibilityConverter}}"
               Foreground ="#d3deea" />

            <TextBlock Text="{Binding Result}"
               FontSize="16"
               Margin="0,20,0,0"
              Foreground="#f18832"
               Visibility="{Binding IsStartEnabled, Converter={StaticResource InverseBoolToVisibilityConverter}}"        
               />

            <TextBlock Text="{Binding ConnectionInfo}"
               FontSize="16"
               Margin="0,20,0,0"
              Foreground="#f18832"
               Visibility="{Binding IsStartEnabled, Converter={StaticResource InverseBoolToVisibilityConverter}}"        
               />

            <ItemsControl ItemsSource="{Binding LastGameResult.Guesses}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Guess}"  Foreground="#f18832" FontSize="14" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
        
        <Image Width="100"  HorizontalAlignment="right" VerticalAlignment="Bottom" Source="/Resources/SaraBauer_logo_round.png"/>


    </Grid>
</Window>
