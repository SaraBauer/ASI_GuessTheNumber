<Window x:Class="ASI_GuessTheNumber.View.NewGamePopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        WindowStyle="None"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        Background="#FFFFFF"
        AllowsTransparency="True"
        BorderThickness="0"
        Padding="20"
>

    <Border Background="White" CornerRadius="12" BorderBrush="#CCCCCC" BorderThickness="1" Padding="20">
        <StackPanel Width="280">

            <TextBlock Text="Correct!"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#2A6F97"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <TextBlock Text="{Binding Message}"
                       FontSize="16"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>
            <ComboBox ItemsSource="{Binding RangeOptions}"
                    SelectedItem="{Binding SelectedRange}"
                    FontSize="14"
                    Margin="0,0,0,20"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

  
                <Button Content="New Game"
                        Width="100"
                        Padding="6"
                        Command="{Binding NewGameCommand}"
                        Background="#2A6F97"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"/>

                <Button Content="Close"
                        Width="100"
                        Padding="6"
                        Command="{Binding CloseCommand}"
                        Background="#DDDDDD"
                        Foreground="Black"
                        BorderThickness="0"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
